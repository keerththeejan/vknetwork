# Block executable scripts, but allow normal image/file access.
<IfModule mod_authz_core.c>
    <FilesMatch "\.(php|phtml|php3|php4|php5|phar)$">
        Require all denied
    </FilesMatch>
</IfModule>

# Apache 2.2 fallback
<IfModule !mod_authz_core.c>
    <FilesMatch "\.(php|phtml|php3|php4|php5|phar)$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>
